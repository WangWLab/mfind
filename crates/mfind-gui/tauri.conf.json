{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mfind",
  "version": "0.1.0",
  "identifier": "com.mfind.gui",
  "build": {
    "frontendDist": "./src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "mfind - Fast File Search",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "deb", "rpm", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libgtk-3-0", "libwebkit2gtk-4.0-37", "libappindicator3-1"],
        "files": {}
      },
      "rpm": {
        "depends": ["gtk3", "webkit2gtk3", "libappindicator-gtk3"],
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    },
    "category": "Utility",
    "shortDescription": "Fast file search tool",
    "longDescription": "mfind is a high-performance file search tool featuring instant search results, real-time index updates, and cross-platform support.",
    "externalBin": [],
    "resources": [],
    "copyright": "Apache 2.0"
  },
  "plugins": {
    "global-shortcut": {
      "mfind-toggle": {
        "shortcut": "CommandOrControl+Shift+F",
        "listen": true
      }
    }
  }
}
